# TM1 Server (VM2 — Windows)
TM1_ADDRESS=192.168.x.x
TM1_PORT=4444
TM1_DATABASE=TM1 Governance
TM1_CLIENT_ID=your_client_id_here
TM1_CLIENT_SECRET=your_client_secret_here
TM1_USER=akadmin

# PAW — IBM Planning Analytics Workspace (VM1 — RHEL)
PAW_HOST=http://192.168.x.x
PAW_ACCOUNT_ID=your_account_id_here
PAW_TENANT_ID=your_tenant_id_here

# Report Builder
REPORT_AUTHOR=Admin                 # Displayed in report metadata until OIDC auth lands

# Authentik SSO (host machine)
AUTHENTIK_HOST=http://192.168.x.x:9000
AUTHENTIK_USERNAME=akadmin
AUTHENTIK_PASSWORD=your_password_here

# Claude API (for spec generation)
ANTHROPIC_API_KEY=
