# ── Server ──────────────────────────────────────────────────────
PORT=8083  # inside container; Docker maps host 8084 → container 8083

# ── TM1 connection (required) ────────────────────────────────────
TM1_ADDRESS=192.168.x.x
TM1_PORT=4444
TM1_DATABASE=YourDatabaseName
TM1_CLIENT_ID=your_client_id_here
TM1_CLIENT_SECRET=your_client_secret_here
TM1_USER=admin

# ── AI spec generation (optional) ───────────────────────────────
ANTHROPIC_API_KEY=
